# AgentOps v4.0 Environment Variables
# Copy this file to .env and fill in values as needed.

# MCP Server Access Key (optional — enables authentication on HTTP transport)
AGENTOPS_ACCESS_KEY=

# CORS Origin (optional — restricts allowed origins when access key is set)
# Default: http://localhost (when access key is set), * (when no access key)
AGENTOPS_CORS_ORIGIN=

# Supabase (optional — for cloud storage provider, currently beta)
SUPABASE_URL=
SUPABASE_KEY=
